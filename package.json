{
  "name": "resultat-ts",
  "version": "0.1.0",
  "description": "A tiny TypeScript Result type for explicit error handling without exceptions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "result",
    "typescript",
    "error-handling",
    "functional",
    "rust-style"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martin-dinahet/resultat-ts"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "^25.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "biome check --write",
    "*.{json,md}": "biome check --write"
  }
}
